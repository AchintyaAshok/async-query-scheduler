# Application
APP_NAME=query_scheduler
APP_ENV=development
APP_DEBUG=true

# Server
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=1
APP_RELOAD=true

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/query_scheduler

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=console
# LOG_FORMAT=json  # Use for production / structured logging

# Snowflake
SNOWFLAKE_ACCOUNT=####
SNOWFLAKE_USER==####
SNOWFLAKE_PASSWORD==####
SNOWFLAKE_WAREHOUSE==####
SNOWFLAKE_DATABASE==####
SNOWFLAKE_SCHEMA==####

# Access Control
QUERY_ACCESS_ENABLED=true
ALLOWED_CAPABILITIES=start_query,get_status,get_results

# Query Limits
MAX_QUERY_LENGTH=10000
QUERY_RESULT_MAX_ROWS=10000

# OpenTelemetry (requires: uv sync --extra otel)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=query_scheduler
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_TRACES_SAMPLER=parentbased_always_on
# OTEL_TRACES_SAMPLER_ARG=0.1  # Sample 10% of traces in production
